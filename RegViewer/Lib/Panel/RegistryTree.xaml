<UserControl x:Class="RegViewer.Lib.Panel.RegistryTree"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RegViewer.Lib.Panel"
             xmlns:lib="clr-namespace:RegViewer.Lib"
             mc:Ignorable="d">
    <Grid>
        <ScrollViewer Name="TreeScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <TreeView Name="TreeView"
                      ItemsSource="{Binding RootKeys}"
                      BorderThickness="0"
                      SelectedItemChanged="TreeView_SelectedItemChanged"
                      PreviewKeyDown="TreeView_PreviewKeyDown"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      PreviewMouseWheel="TreeView_PreviewMouseWheel"
                      PreviewMouseDown="TreeView_PreviewMouseDown">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type lib:KeyItem}"
                                              ItemsSource="{Binding SubKeys}">
                        <TextBlock Text="{Binding Name}"
                                       FontWeight="Bold"
                                       Margin="0,0,5,0"
                                       FontSize="12"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>
    </Grid>
</UserControl>
