                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
            <StackPanel Orientation="Vertical">
                <Label Content="aaaa" />
                <Label Content="aaaa" />
                <Label Content="aaaa" />
                <Label Content="aaaa" />
            </StackPanel>
        </Border>
        
        <Label Grid.Row="2" Grid.Column="0" Content="Status: Ready" />
    </Grid>
