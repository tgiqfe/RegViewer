<Window x:Class="RegViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RegViewer"
        xmlns:lib="clr-namespace:RegViewer.Lib"
        xmlns:panel="clr-namespace:RegViewer.Lib.Panel"
        mc:Ignorable="d"
        Title="MainWindow"
        Left="{Binding Setting.Left, Mode=TwoWay}"
        Top="{Binding Setting.Top, Mode=TwoWay}"
        Height="{Binding Setting.Height, Mode=TwoWay}"
        Width="{Binding Setting.Width, Mode=TwoWay}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <panel:RegistryAddressBar Grid.Row="0" Grid.ColumnSpan="2" 
                                  x:Name="AddressBar" />

        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
            <panel:RegistryTree x:Name="RootKeys" />
        </Border>

        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
            <StackPanel Orientation="Vertical">
                <Label Content="aaaa" />
                <Label Content="aaaa" />
                <Label Content="aaaa" />
                <Label Content="aaaa" />
            </StackPanel>
        </Border>

        <Label Grid.Row="2" Grid.Column="0" Content="Status: Ready" />
    </Grid>
</Window>
