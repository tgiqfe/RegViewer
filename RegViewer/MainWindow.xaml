<Window x:Class="RegViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RegViewer"
        xmlns:lib="clr-namespace:RegViewer.Lib"
        xmlns:panel="clr-namespace:RegViewer.Lib.Panel"
        mc:Ignorable="d"
        Title="MainWindow"
        Left="{Binding Setting.Left, Mode=TwoWay}"
        Top="{Binding Setting.Top, Mode=TwoWay}"
        Height="{Binding Setting.Height, Mode=TwoWay}"
        Width="{Binding Setting.Width, Mode=TwoWay}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1">
            <TextBox Name="AddressBar"
                     Text=""
                     VerticalContentAlignment="Center"
                     FontSize="12" />
        </Border>

        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
            <ScrollViewer Name="TreeScrollViewer" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical">

                    <panel:RegistryTree x:Name="Tree_HKCR" KeyItems="{Binding Key_HKCR}" />

                    <panel:RegistryTree x:Name="Tree_HKCU" KeyItems="{Binding Key_HKCU}" />

                    <panel:RegistryTree x:Name="Tree_HKLM" KeyItems="{Binding Key_HKLM}" />

                    <panel:RegistryTree x:Name="Tree_HKU" KeyItems="{Binding Key_HKU}" />
                    
                    <panel:RegistryTree x:Name="Tree_HKCC" KeyItems="{Binding Key_HKCC}" />

