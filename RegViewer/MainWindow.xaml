<Window x:Class="RegViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RegViewer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
            <ScrollViewer Name="TreeScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical">
                    <TreeView Name="TreeView1" ItemsSource="{Binding Keys1}" BorderThickness="0" SelectedItemChanged="TreeView_SelectedItemChanged"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="TreeView_PreviewMouseWheel">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type local:KeyItem}"
                                                      ItemsSource="{Binding SubKeys}">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,5,0" />
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <TreeView Name="TreeView2" ItemsSource="{Binding Keys2}" BorderThickness="0" SelectedItemChanged="TreeView_SelectedItemChanged"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="TreeView_PreviewMouseWheel">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type local:KeyItem}"
                                                      ItemsSource="{Binding SubKeys}">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,5,0" />
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Border Grid.Row="0" Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
            <StackPanel Orientation="Vertical">
                <Label Content="aaaa" />
                <Label Content="aaaa" />
                <Label Content="aaaa" />
                <Label Content="aaaa" />
            </StackPanel>
        </Border>
        
        <Label Grid.Row="1" Grid.Column="0" Content="Status: Ready" />
    </Grid>
</Window>
